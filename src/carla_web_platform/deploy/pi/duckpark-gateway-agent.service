[Unit]
Description=DuckPark Pi Gateway Agent
After=network-online.target duckpark-uvc-gadget.service
Wants=network-online.target duckpark-uvc-gadget.service

[Service]
Type=simple
WorkingDirectory=/opt/duckpark/carla_web_platform
EnvironmentFile=/etc/duckpark/pi-gateway.env
ExecStart=/bin/bash /opt/duckpark/carla_web_platform/scripts/start_pi_gateway_agent.sh
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
