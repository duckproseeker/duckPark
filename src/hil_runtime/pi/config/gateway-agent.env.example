PI_GATEWAY_API_BASE_URL=http://192.168.110.151:8000
PI_GATEWAY_ID=rpi5-x1301-01
PI_GATEWAY_NAME=bench-a
PI_GATEWAY_INPUT_VIDEO_DEVICE=/dev/video0
# 留空时自动探测 rp1-cfe media device（Pi 5 + X1301 常见为 /dev/media3）
PI_GATEWAY_MEDIA_DEVICE=
PI_GATEWAY_HDMI_STATUS_DEVICE=/dev/v4l-subdev2
PI_GATEWAY_HEARTBEAT_INTERVAL_SECONDS=5
PI_GATEWAY_STATE_DIR=/opt/duckpark/src/carla_web_platform/run_data/pi_gateway
# 当前演示建议 USB 只做 UVC 摄像头，Jetson 管理和结果回传走独立有线网络。
PI_GATEWAY_USB_GADGET_MODE=uvc_only
# 只有在复合 gadget 模式（uvc_ecm）下才需要下面两项。
# PI_GATEWAY_USB_NETWORK_INTERFACE=usb0
# PI_GATEWAY_USB_NETWORK_CIDR=192.168.7.1/24
PI_GATEWAY_DUT_RESULT_FILE=/opt/duckpark/src/carla_web_platform/run_data/pi_gateway/dut_result.json
PI_GATEWAY_DUT_RESULT_RECEIVER_HOST=0.0.0.0
PI_GATEWAY_DUT_RESULT_RECEIVER_PORT=8765
