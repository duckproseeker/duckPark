SERVICE_NAME=carla-sim-control-mvp
API_HOST=127.0.0.1
API_PORT=8000

# Remote CARLA server
CARLA_HOST=192.168.110.151
CARLA_PORT=2000
TRAFFIC_MANAGER_PORT=8010
CARLA_TIMEOUT_SECONDS=10.0

# Local storage
RUNS_ROOT=./run_data/runs
COMMANDS_ROOT=./run_data/commands
ARTIFACTS_ROOT=./artifacts

# Set to false when you only need the Web/API surface on an unsupported laptop.
START_EXECUTOR=true

# Optional: path to an external official ScenarioRunner checkout.
# The platform only uses it to discover official `.xosc` example files as input assets;
# it no longer executes `scenario_runner.py` as the runtime.
# SCENARIO_RUNNER_ROOT=./external/scenario_runner

# Optional HIL sidecar orchestration. Commands are executed via `bash -lc` from the `src/` root.
HIL_ORCHESTRATION_ENABLED=true
HIL_COMMAND_TIMEOUT_SECONDS=90
HIL_PLATFORM_BASE_URL=http://127.0.0.1:8000

# When the executor runs inside a container without `docker`, point Host CARLA / Host Display
# orchestration back to the physical host via SSH.
# DUCKPARK_HOST_SSH_HOST=192.168.110.151
# DUCKPARK_HOST_SSH_USER=du
# DUCKPARK_HOST_SSH_PORT=22
# DUCKPARK_HOST_SSH_IDENTITY_FILE=/root/.ssh/id_ed25519_duckpark
# DUCKPARK_HOST_SRC_ROOT=/home/du/ros2-humble/src
# HIL_HOST_CARLA_START_COMMAND="bash hil_runtime/host/scripts/start_host_carla_remote.sh"
# HIL_HOST_CARLA_STOP_COMMAND="bash hil_runtime/host/scripts/stop_host_carla_remote.sh"
# HIL_HOST_DISPLAY_START_COMMAND="bash hil_runtime/host/scripts/start_host_display_remote.sh"
# HIL_HOST_DISPLAY_STOP_COMMAND="bash hil_runtime/host/scripts/stop_host_display_remote.sh"

# Host + Pi only orchestration. Configure SSH key auth from the runtime container/host to the Pi,
# then let Web runs manage CARLA headed display plus Pi RTP streaming. Keep Jetson manual by
# leaving HIL_JETSON_* unset when the DUT can be swapped freely.
# DUCKPARK_PI_HOST=192.168.110.236
# DUCKPARK_PI_USER=kavin
# DUCKPARK_PI_PORT=22
# DUCKPARK_PI_SSH_IDENTITY_FILE=/root/.ssh/id_ed25519_duckpark
# DUCKPARK_PI_RUNTIME_ROOT=$HOME/duckPark/src/hil_runtime
# DUCKPARK_PI_LEGACY_PLATFORM_ROOT=$HOME/duckpark/carla_web_platform
# DUCKPARK_PI_RTP_LOG_FILE=/tmp/duckpark_pi_rtp_stream.log
# PI_HDMI_RTP_TARGET_HOST=192.168.50.2
# PI_HDMI_RTP_TARGET_PORT=5000
# HIL_PI_START_COMMAND="bash hil_runtime/host/scripts/start_pi_rtp_stream_remote.sh"
# HIL_PI_STOP_COMMAND="bash hil_runtime/host/scripts/stop_pi_rtp_stream_remote.sh"

# Keep Jetson manual for the narrowed Host -> Pi -> Jetson flow. Only set these if Web should also
# own DUT startup/shutdown.
# HIL_JETSON_START_COMMAND="ssh jetson-user@jetson-host 'JETSON_CPP_DETECTOR_WRAP_NON_ROS_DEMO=1 bash ~/duckPark/src/hil_runtime/jetson/scripts/start_jetson_cpp_detector.sh'"
# HIL_JETSON_STOP_COMMAND="ssh jetson-user@jetson-host 'pkill -f duckpark_cpp_detector || true'"
