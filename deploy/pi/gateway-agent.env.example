PI_GATEWAY_API_BASE_URL=http://192.168.110.151:8000
PI_GATEWAY_ID=rpi5-x1301-01
PI_GATEWAY_NAME=bench-a
PI_GATEWAY_INPUT_VIDEO_DEVICE=/dev/video0
# 留空时自动探测 rp1-cfe media device（Pi 5 + X1301 常见为 /dev/media3）
PI_GATEWAY_MEDIA_DEVICE=
PI_GATEWAY_HDMI_STATUS_DEVICE=/dev/v4l-subdev2
PI_GATEWAY_HEARTBEAT_INTERVAL_SECONDS=5
PI_GATEWAY_STATE_DIR=/opt/duckpark/carla_web_platform/run_data/pi_gateway
